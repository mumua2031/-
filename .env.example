# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional. Leave empty when frontend and backend are on the same Vercel domain.
# Use this only if the API is deployed on another domain.
VITE_API_BASE_URL=""

# Optional but recommended before enabling admin writes.
# Put the same value in the admin upload page token field.
ADMIN_API_TOKEN="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# Optional Firestore backend. If these are not configured, /api/patterns
# falls back to src/data.ts so the public site remains available.
FIREBASE_PROJECT_ID=""
FIREBASE_DATABASE_ID=""
FIREBASE_STORAGE_BUCKET=""

# 免费自动发布图片：上传图片后会自动写入 GitHub 的 public/patterns 目录并触发 Vercel 部署。
GITHUB_UPLOAD_TOKEN=""
GITHUB_REPOSITORY=""
GITHUB_BRANCH="main"

# Preferred on Vercel: paste the full service account JSON as one env var.
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Alternative to FIREBASE_SERVICE_ACCOUNT_JSON.
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
